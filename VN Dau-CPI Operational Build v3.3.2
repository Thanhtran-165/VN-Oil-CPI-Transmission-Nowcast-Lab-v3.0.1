truyenDanRongRaw = 0.35 * nz(khoiSucEp, 0.50) + 0.25 * nz(khoiOnDinh, 0.50) + 0.20 * nz(khoiTinCay, 0.50) + 0.20 * nz(khoiTruyenDan, 0.50)
truyenDanRong = ta.sma(truyenDanRongRaw, lamMuotF2)

mucKhuechDai = not na(truyenDanRong) and not na(apLucTrucTiep) ? truyenDanRong - apLucTrucTiep : na

cheDoTong = f_cheDoTruyenDan(
    apLucTrucTiep,
    truyenDanRong,
    mucKhuechDai,
    soThangXacNhan,
    nguongKheHo,
    nguongHeThong,
    diemXacNhanTrucTiep,
    tongXacNhan
)

