//@version=6
indicator("VN Dau-CPI Operational Build v3.3.2", shorttitle="VN Dau-CPI OB v3.3.2", overlay=false, max_labels_count=500, max_lines_count=300, max_bars_back=5000)

//======================================================
// 1) CHINH SACH CO DINH
//======================================================
const string MA_DAU       = "TVC:UKOIL"
const string CPI_MOM_GOC  = "ECONOMICS:VNIRMM"
const string CPI_YOY_GOC  = "ECONOMICS:VNIRYY"
const string CPI_VANTAI   = "ECONOMICS:VNCPIT"
const int DO_TRE_CPI      = 1

//======================================================
// 2) DAU VAO
//======================================================
nhomMoHinh    = "1. Mo hinh"
nhomHienThi   = "2. Hien thi"
nhomNguong    = "3. Nguong"
nhomTruyenDan = "4. Truyen dan"
nhomResearch  = "5. Research"

cheDoBang = input.int(3, "Bang (1=Direct Lab, 2=Headline Lab, 3=Transmission)", minval=1, maxval=3, group=nhomHienThi)
mucTieuTongThe = input.string("CPI MoM", "Muc tieu tong the", options=["CPI MoM", "CPI YoY"], group=nhomMoHinh)

doDaiCorr      = input.int(24, "Cua so tuong quan (thang)", minval=12, maxval=60, group=nhomMoHinh)
doDaiZ         = input.int(24, "Cua so z-score", minval=12, maxval=60, group=nhomMoHinh)
doDaiOnDinh    = input.int(12, "Cua so on dinh", minval=6, maxval=24, group=nhomMoHinh)
doDaiSmoothVT  = input.int(3, "Lam muot VNCPIT", minval=1, maxval=12, group=nhomResearch)

// default van giu Raw
luaChonProxyDirect = input.string("VNCPIT Raw", "Proxy direct", options=["VNCPIT Raw", "VNCPIT Smooth", "Blended"], group=nhomResearch)

nguongCorrManh = input.float(0.50, "Nguong corr manh", minval=0.20, maxval=0.90, step=0.05, group=nhomNguong)
nguongCorrVua  = input.float(0.30, "Nguong corr vua", minval=0.10, maxval=0.80, step=0.05, group=nhomNguong)
nguongShockZ   = input.float(1.00, "Nguong shock dau z", minval=0.50, maxval=3.00, step=0.10, group=nhomNguong)

nguongKheHo    = input.float(0.12, "Nguong muc khuech dai", minval=0.02, maxval=1.00, step=0.01, group=nhomTruyenDan)
soThangXacNhan = input.int(3, "So thang xac nhan truyen dan", minval=1, maxval=12, group=nhomTruyenDan)
nguongHeThong  = input.float(0.22, "Nguong stress he thong", minval=0.05, maxval=1.50, step=0.01, group=nhomTruyenDan)
lamMuotF2      = input.int(3, "Lam muot diem truyen dan", minval=1, maxval=12, group=nhomTruyenDan)

hienBang       = input.bool(true, "Hien bang tom tat", group=nhomHienThi)
hienNen        = input.bool(true, "Hien nen theo trang thai", group=nhomHienThi)
hienDuongDau   = input.bool(true, "Hien duong shock dau", group=nhomHienThi)
hienDuongDiem  = input.bool(true, "Hien cac duong diem", group=nhomHienThi)
hienNhanDuong  = input.bool(true, "Hien nhan ten duong", group=nhomHienThi)

//======================================================
// 3) HAM HO TRO
//======================================================
f_phanTram(v) =>
    na(v) ? "NA" : str.tostring(v, "#.##") + "%"

f_so(v) =>
    na(v) ? "NA" : str.tostring(v, "#.###")

f_z(src, len) =>
    _m = ta.sma(src, len)
    _s = ta.stdev(src, len)
    na(_m) or na(_s) or _s == 0 ? na : (src - _m) / _s

f_ep(v, lo, hi) =>
    math.max(lo, math.min(hi, v))

f_chuanHoa01(v, lo, hi) =>
    na(v) or hi == lo ? na : f_ep((v - lo) / (hi - lo), 0.0, 1.0)

f_beta(x, y, len) =>
    _corr = ta.correlation(x, y, len)
    _sx   = ta.stdev(x, len)
    _sy   = ta.stdev(y, len)
    not na(_corr) and not na(_sx) and not na(_sy) and _sx != 0 ? _corr * (_sy / _sx) : na

f_best_lag_012(c0, c1, c2) =>
    _a0 = na(c0) ? -1.0 : math.abs(c0)
    _a1 = na(c1) ? -1.0 : math.abs(c1)
    _a2 = na(c2) ? -1.0 : math.abs(c2)
    _lag = 0
    _val = _a0
    if _a1 > _val
        _val := _a1
        _lag := 1
    if _a2 > _val
        _val := _a2
        _lag := 2
    [_lag, _val]

f_khoangCach(c0, c1, c2, bestLag) =>
    _a0 = na(c0) ? 0.0 : math.abs(c0)
    _a1 = na(c1) ? 0.0 : math.abs(c1)
    _a2 = na(c2) ? 0.0 : math.abs(c2)
    _tot = bestLag == 0 ? _a0 : bestLag == 1 ? _a1 : _a2
    _nhi = 0.0
    if bestLag == 0
        _nhi := math.max(_a1, _a2)
    else if bestLag == 1
        _nhi := math.max(_a0, _a2)
    else
        _nhi := math.max(_a0, _a1)
    _tot - _nhi

f_doDongDau(src, len) =>
    _cungDau = 0.0
    _dem = 0.0
    for i = 0 to len - 1
        if not na(src[i]) and not na(src[i + 1])
            _dem += 1
            if (src[i] >= 0 and src[i + 1] >= 0) or (src[i] < 0 and src[i + 1] < 0)
                _cungDau += 1
    _dem > 0 ? _cungDau / _dem : na

f_cheDoOnDinh(corrSeries, betaSeries, lagGap, nguongManh, nguongVua, len) =>
    _tbAbsCorr = ta.sma(math.abs(corrSeries), len)
    _stdCorr   = ta.stdev(corrSeries, len)
    _dongNhatBeta = f_doDongDau(betaSeries, len)

    float _diem = 0.0
    if not na(_tbAbsCorr)
        if _tbAbsCorr >= nguongManh
            _diem += 2.0
        else if _tbAbsCorr >= nguongVua
            _diem += 1.0

    if not na(_stdCorr)
        if _stdCorr <= 0.10
            _diem += 2.0
        else if _stdCorr <= 0.20
            _diem += 1.0

    if not na(_dongNhatBeta)
        if _dongNhatBeta >= 0.85
            _diem += 2.0
        else if _dongNhatBeta >= 0.65
            _diem += 1.0

    if not na(lagGap)
        if lagGap >= 0.15
            _diem += 2.0
        else if lagGap >= 0.05
            _diem += 1.0

    string _cheDo = "Yeu/Vo"
    if _diem >= 7
        _cheDo := "On dinh manh"
    else if _diem >= 5
        _cheDo := "On dinh vua"
    else if _diem >= 3
        _cheDo := "Khong on dinh"
    else
        _cheDo := "Yeu/Vo"

    [_diem, _cheDo, _tbAbsCorr, _stdCorr, _dongNhatBeta]

f_doTinCayLienKet(corrAbs, bestLag, cheDo) =>
    float _nen = 0.0
    if na(corrAbs)
        _nen := 0.0
    else if corrAbs >= 0.50
        _nen := 0.85
    else if corrAbs >= 0.30
        _nen := 0.65
    else if corrAbs >= 0.20
        _nen := 0.48
    else if corrAbs >= 0.10
        _nen := 0.32
    else
        _nen := 0.18

    float _phat = 0.0
    if bestLag == 1
        _phat := 0.08
    else if bestLag == 2
        _phat := 0.16

    float _dieuChinh = 0.0
    if cheDo == "On dinh manh"
        _dieuChinh := 0.10
    else if cheDo == "On dinh vua"
        _dieuChinh := 0.03
    else if cheDo == "Khong on dinh"
        _dieuChinh := -0.05
    else
        _dieuChinh := -0.12

    _conf = math.max(0.0, math.min(1.0, _nen - _phat + _dieuChinh))

    string _nhan = "Thap"
    if _conf >= 0.72
        _nhan := "Cao"
    else if _conf >= 0.48
        _nhan := "Vua"
    else
        _nhan := "Thap"

    [_conf, _nhan]

f_xacNhanTrucTiep(cheDo, apLucNhan, corr0Abs) =>
    string _out = "Yeu"
    if (cheDo == "On dinh manh" or cheDo == "On dinh vua") and (apLucNhan == "Cao" or apLucNhan == "Vua") and not na(corr0Abs) and corr0Abs >= 0.20
        _out := "Xac nhan"
    else if not na(corr0Abs) and corr0Abs >= 0.12 and (apLucNhan == "Cao" or apLucNhan == "Vua")
        _out := "Co dau hieu"
    else
        _out := "Yeu"
    _out

f_textDoTre(bestLag) =>
    string _out = "Khong ro"
    if bestLag == 0
        _out := "Cung thang"
    else if bestLag == 1
        _out := "Tre 1 thang"
    else if bestLag == 2
        _out := "Tre 2 thang"
    _out

f_cheDoTruyenDan(f1, f2, gap, soThang, nguongGap, nguongHeThong, xacNhanTrucTiep, xacNhanHeThong) =>
    _trucTiepNow = not na(f1) and f1 >= 0.10 and xacNhanTrucTiep >= 1
    _khuechDaiNow = not na(gap) and gap >= nguongGap and not na(f2) and f2 >= 0.55 and xacNhanHeThong >= 2
    _heThongNow = not na(gap) and gap >= nguongHeThong and not na(f2) and f2 >= 0.70 and xacNhanHeThong >= 2

    _trucTiepPersist = ta.barssince(not _trucTiepNow) >= soThang - 1
    _khuechDaiPersist = ta.barssince(not _khuechDaiNow) >= soThang - 1
    _heThongPersist = ta.barssince(not _heThongNow) >= soThang - 1

    string _cheDo = "Binh thuong"
    if _heThongPersist
        _cheDo := "Stress he thong"
    else if _khuechDaiPersist
        _cheDo := "Khuech dai"
    else if _trucTiepPersist
        _cheDo := "Shock truc tiep"
    else if not na(f1) and f1 > 0
        _cheDo := "Som"
    else
        _cheDo := "Binh thuong"
    _cheDo

f_nhanApLuc(v, zThr) =>
    string _out = "Thap"
    if not na(v)
        if v >= zThr * 0.30
            _out := "Cao"
        else if v > 0
            _out := "Vua"
        else if v <= -zThr * 0.30
            _out := "Giam ap luc"
        else
            _out := "Thap"
    _out

f_huongApLuc(v, zThr) =>
    string _out = "NA"
    if not na(v)
        if v >= zThr * 0.30
            _out := "Tang"
        else if v > 0
            _out := "Tang"
        else if v <= -zThr * 0.30
            _out := "Giam"
        else
            _out := "Di ngang"
    _out

f_doManhHienTai(apLucNhan, gap, cheDoTong, xacNhanTrucTiep) =>
    float _score = 0.0

    if cheDoTong == "Stress he thong"
        _score += 0.45
    else if cheDoTong == "Khuech dai"
        _score += 0.35
    else if cheDoTong == "Shock truc tiep"
        _score += 0.22
    else if cheDoTong == "Som"
        _score += 0.10

    if apLucNhan == "Cao"
        _score += 0.35
    else if apLucNhan == "Vua"
        _score += 0.20
    else if apLucNhan == "Giam ap luc"
        _score -= 0.10

    if not na(gap)
        if gap >= 0.25
            _score += 0.20
        else if gap >= 0.12
            _score += 0.10
        else if gap > 0
            _score += 0.05

    if xacNhanTrucTiep == "Xac nhan"
        _score += 0.15
    else if xacNhanTrucTiep == "Co dau hieu"
        _score += 0.05
    else
        _score -= 0.08

    _score := f_ep(_score, 0.0, 1.0)

    string _label = "Thap"
    if _score >= 0.75
        _label := "Rat manh"
    else if _score >= 0.50
        _label := "Manh"
    else if _score >= 0.28
        _label := "Vua"
    else
        _label := "Thap"

    [_score, _label]

// giu nguyen ban siết v3.3.1
f_tinCayCheDo(mucKhuechDai, cheDoTong, tongXacNhan, doDai) =>
    _gapDuongTyLe = ta.sma((not na(mucKhuechDai) and mucKhuechDai > 0) ? 1.0 : 0.0, doDai)
    _gapOnDinh = ta.stdev(mucKhuechDai, doDai)
    _xacNhanHeThong = f_chuanHoa01(tongXacNhan, 0.0, 3.0)

    float _score = 0.0

    if not na(_gapDuongTyLe)
        if _gapDuongTyLe >= 0.88
            _score += 0.36
        else if _gapDuongTyLe >= 0.72
            _score += 0.24
        else if _gapDuongTyLe >= 0.55
            _score += 0.12

    if not na(_gapOnDinh)
        if _gapOnDinh <= 0.10
            _score += 0.20
        else if _gapOnDinh <= 0.16
            _score += 0.12
        else if _gapOnDinh <= 0.24
            _score += 0.05

    if not na(_xacNhanHeThong)
        _score += 0.22 * _xacNhanHeThong

    if cheDoTong == "Stress he thong"
        _score += 0.06
    else if cheDoTong == "Khuech dai"
        _score += 0.05
    else if cheDoTong == "Shock truc tiep"
        _score += 0.02

    _score := f_ep(_score, 0.0, 1.0)

    string _label = "Thap"
    if _score >= 0.78
        _label := "Cao"
    else if _score >= 0.50
        _label := "Vua"
    else
        _label := "Thap"

    [_score, _label]

//======================================================
// 4) DU LIEU
//======================================================
dauM     = request.security(MA_DAU, "M", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dauMoM   = request.security(MA_DAU, "M", open,  gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

cpiMoMRaw = request.security(CPI_MOM_GOC, "M", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
cpiYoYRaw = request.security(CPI_YOY_GOC, "M", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
vncpitRaw = request.security(CPI_VANTAI, "M", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

//======================================================
// 5) CAN CHINH CHUOI
//======================================================
dauRetM  = not na(dauM) and not na(dauM[1]) ? (dauM / dauM[1] - 1.0) * 100.0 : na
dauMTD   = not na(dauM) and not na(dauMoM) and dauMoM != 0 ? (dauM / dauMoM - 1.0) * 100.0 : na
zDauSong = f_z(dauMTD, doDaiZ)

cpiMoMRef = cpiMoMRaw[DO_TRE_CPI]
cpiYoYRef = cpiYoYRaw[DO_TRE_CPI]

float cpiTongTheRef = na
if mucTieuTongThe == "CPI MoM"
    cpiTongTheRef := cpiMoMRef
else
    cpiTongTheRef := cpiYoYRef

vncpitMoMRaw = not na(vncpitRaw) and not na(vncpitRaw[1]) and vncpitRaw[1] != 0 ? (vncpitRaw / vncpitRaw[1] - 1.0) * 100.0 : na
vncpitSmooth = ta.sma(vncpitMoMRaw, doDaiSmoothVT)

float proxyDirect = na
if luaChonProxyDirect == "VNCPIT Raw"
    proxyDirect := vncpitMoMRaw[DO_TRE_CPI]
else if luaChonProxyDirect == "VNCPIT Smooth"
    proxyDirect := vncpitSmooth[DO_TRE_CPI]
else
    proxyDirect := 0.50 * vncpitMoMRaw[DO_TRE_CPI] + 0.50 * vncpitSmooth[DO_TRE_CPI]

vncpitRef = vncpitMoMRaw[DO_TRE_CPI]

//======================================================
// 6) KENH TRUC TIEP: DAU -> PROXY DIRECT
//======================================================
duDuLieuTrucTiep = not na(proxyDirect) and not na(proxyDirect[doDaiCorr]) and not na(dauRetM[DO_TRE_CPI + 2])

dCorr0_raw = ta.correlation(dauRetM[DO_TRE_CPI],     proxyDirect, doDaiCorr)
dCorr1_raw = ta.correlation(dauRetM[DO_TRE_CPI + 1], proxyDirect, doDaiCorr)
dCorr2_raw = ta.correlation(dauRetM[DO_TRE_CPI + 2], proxyDirect, doDaiCorr)
dBeta0_raw = f_beta(dauRetM[DO_TRE_CPI], proxyDirect, doDaiCorr)

dCorr0 = duDuLieuTrucTiep ? dCorr0_raw : na
dCorr1 = duDuLieuTrucTiep ? dCorr1_raw : na
dCorr2 = duDuLieuTrucTiep ? dCorr2_raw : na
dBeta0 = duDuLieuTrucTiep ? dBeta0_raw : na

[dBestLag, _dBestAbs] = f_best_lag_012(dCorr0, dCorr1, dCorr2)

float dBestCorr = na
if dBestLag == 0
    dBestCorr := dCorr0
else if dBestLag == 1
    dBestCorr := dCorr1
else
    dBestCorr := dCorr2

dGap = f_khoangCach(dCorr0, dCorr1, dCorr2, dBestLag)
[dDiemOnDinh, dCheDo, dTbAbsCorr, dStdCorr, dDongNhatBeta] = f_cheDoOnDinh(dCorr0, dBeta0, dGap, nguongCorrManh, nguongCorrVua, doDaiOnDinh)

dApLuc = not na(zDauSong) and not na(dCorr0) ? zDauSong * dCorr0 : na
dNhanApLuc = f_nhanApLuc(dApLuc, nguongShockZ)
dHuongApLuc = f_huongApLuc(dApLuc, nguongShockZ)

[dTinCayDirectScore, dTinCayDirectNhan] = f_doTinCayLienKet(math.abs(dCorr0), dBestLag, dCheDo)
dXacNhan = f_xacNhanTrucTiep(dCheDo, dNhanApLuc, math.abs(dCorr0))

//======================================================
// 7) KENH TONG THE: DAU -> CPI TONG THE
//======================================================
duDuLieuTongThe = not na(cpiTongTheRef) and not na(cpiTongTheRef[doDaiCorr]) and not na(dauRetM[DO_TRE_CPI + 2])

hCorr0_raw = ta.correlation(dauRetM[DO_TRE_CPI],     cpiTongTheRef, doDaiCorr)
hCorr1_raw = ta.correlation(dauRetM[DO_TRE_CPI + 1], cpiTongTheRef, doDaiCorr)
hCorr2_raw = ta.correlation(dauRetM[DO_TRE_CPI + 2], cpiTongTheRef, doDaiCorr)
hBeta0_raw = f_beta(dauRetM[DO_TRE_CPI], cpiTongTheRef, doDaiCorr)

hCorr0 = duDuLieuTongThe ? hCorr0_raw : na
hCorr1 = duDuLieuTongThe ? hCorr1_raw : na
hCorr2 = duDuLieuTongThe ? hCorr2_raw : na
hBeta0 = duDuLieuTongThe ? hBeta0_raw : na

[hBestLag, _hBestAbs] = f_best_lag_012(hCorr0, hCorr1, hCorr2)

float hBestCorr = na
if hBestLag == 0
    hBestCorr := hCorr0
else if hBestLag == 1
    hBestCorr := hCorr1
else
    hBestCorr := hCorr2

hGap = f_khoangCach(hCorr0, hCorr1, hCorr2, hBestLag)
[hDiemOnDinh, hCheDo, hTbAbsCorr, hStdCorr, hDongNhatBeta] = f_cheDoOnDinh(hCorr0, hBeta0, hGap, nguongCorrManh, nguongCorrVua, doDaiOnDinh)

hApLuc = not na(zDauSong) and not na(hCorr0) ? zDauSong * hCorr0 : na
hNhanApLuc = f_nhanApLuc(hApLuc, nguongShockZ)
hHuongApLuc = f_huongApLuc(hApLuc, nguongShockZ)

[hTinCayHeadlineScore, hTinCayHeadlineNhan] = f_doTinCayLienKet(math.abs(hCorr0), hBestLag, hCheDo)
hXacNhan = f_xacNhanTrucTiep(hCheDo, hNhanApLuc, math.abs(hCorr0))

//======================================================
// 8) LOP KHUYECH DAI
//======================================================
float apLucTrucTiep = na
if not na(dApLuc) and not na(hApLuc)
    apLucTrucTiep := 0.45 * dApLuc + 0.55 * hApLuc
else if not na(hApLuc)
    apLucTrucTiep := hApLuc
else if not na(dApLuc)
    apLucTrucTiep := dApLuc

blockApLucTongThe   = f_chuanHoa01(hApLuc, -nguongShockZ, nguongShockZ)
blockApLucTrucTiep = f_chuanHoa01(dApLuc, -nguongShockZ, nguongShockZ)

float khoiSucEp = na
if not na(blockApLucTongThe) and not na(blockApLucTrucTiep)
    khoiSucEp := 0.65 * blockApLucTongThe + 0.35 * blockApLucTrucTiep
else if not na(blockApLucTongThe)
    khoiSucEp := blockApLucTongThe
else if not na(blockApLucTrucTiep)
    khoiSucEp := blockApLucTrucTiep

blockOnDinhTongThe   = f_chuanHoa01(hDiemOnDinh, 0.0, 8.0)
blockOnDinhTrucTiep = f_chuanHoa01(dDiemOnDinh, 0.0, 8.0)

float khoiOnDinh = na
if not na(blockOnDinhTongThe) and not na(blockOnDinhTrucTiep)
    khoiOnDinh := 0.60 * blockOnDinhTongThe + 0.40 * blockOnDinhTrucTiep
else if not na(blockOnDinhTongThe)
    khoiOnDinh := blockOnDinhTongThe
else if not na(blockOnDinhTrucTiep)
    khoiOnDinh := blockOnDinhTrucTiep

float khoiTinCay = na
if not na(hTinCayHeadlineScore) and not na(dTinCayDirectScore)
    khoiTinCay := 0.60 * hTinCayHeadlineScore + 0.40 * dTinCayDirectScore
else if not na(hTinCayHeadlineScore)
    khoiTinCay := hTinCayHeadlineScore
else if not na(dTinCayDirectScore)
    khoiTinCay := dTinCayDirectScore

float diemXacNhanTrucTiep = 0.0
if dXacNhan == "Xac nhan"
    diemXacNhanTrucTiep := 1.0
else if dXacNhan == "Co dau hieu"
    diemXacNhanTrucTiep := 0.7
else if dXacNhan == "Yeu"
    diemXacNhanTrucTiep := 0.3
else
    diemXacNhanTrucTiep := 0.0

int xn1 = 0
int xn2 = 0
int xn3 = 0

if hNhanApLuc == "Cao" or hNhanApLuc == "Vua"
    xn1 := 1
if dNhanApLuc == "Cao" or dNhanApLuc == "Vua"
    xn2 := 1
if hCheDo == "On dinh manh" or hCheDo == "On dinh vua"
    xn3 := 1

tongXacNhan = xn1 + xn2 + xn3
diemXacNhanHeThong = f_chuanHoa01(tongXacNhan, 0.0, 3.0)

float phatDoTre = 0.0
if hBestLag == 0
