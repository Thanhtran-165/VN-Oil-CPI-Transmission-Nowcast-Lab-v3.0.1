f_ketLuanVanHanh(doManh, cheDoTong, tinCayCheDo, xacNhanTrucTiep, mucKhuechDai, apLucNhan) =>
    string _out = "Chua xac nhan"

    _gapDuong = not na(mucKhuechDai) and mucKhuechDai > 0
    _coCanhBao = xacNhanTrucTiep == "Xac nhan" or xacNhanTrucTiep == "Co dau hieu"

    if doManh == "Rat manh" and (cheDoTong == "Khuech dai" or cheDoTong == "Stress he thong") and (tinCayCheDo == "Vua" or tinCayCheDo == "Cao")
        _out := "Canh bao manh"
    else if (doManh == "Manh" or doManh == "Rat manh") and _gapDuong and _coCanhBao
        _out := "Canh bao"
    else if apLucNhan == "Cao" or apLucNhan == "Vua" or _gapDuong
        _out := "Theo doi"
    else
        _out := "Chua xac nhan"

    _out

f_tomTatVanHanh(ketLuanVanHanh, cheDoTong, doManh, tinCayDirect, tinCayCheDo) =>
    string _txt = "Tin hieu chua ro."
    if ketLuanVanHanh == "Canh bao manh"
        _txt := "Shock manh | " + cheDoTong + " dang hoat dong | Muc canh bao: Canh bao manh."
    else if ketLuanVanHanh == "Canh bao"
        _txt := "Shock ro | Truyen dan dang mo rong | Muc canh bao: Canh bao."
    else if ketLuanVanHanh == "Theo doi"
        _txt := "Shock dang hinh thanh tac dong | Muc canh bao: Theo doi."
    else
        _txt := "Chua du xac nhan de nang muc canh bao."

    _txt := _txt + " Do manh: " + doManh + "."
    _txt := _txt + " Direct: " + tinCayDirect + "."
    _txt := _txt + " Che do: " + tinCayCheDo + "."
    _txt

